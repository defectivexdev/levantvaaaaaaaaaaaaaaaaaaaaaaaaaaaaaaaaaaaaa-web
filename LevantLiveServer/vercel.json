{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ],
  "env": {
    "MONGODB_URI": "@mongodb_uri",
    "BASE_URL": "@base_url",
    "ACARS_API_KEY": "@acars_api_key",
    "NODE_ENV": "production"
  }
}
