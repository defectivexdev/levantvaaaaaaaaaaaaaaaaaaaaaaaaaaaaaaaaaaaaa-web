<UserControl x:Class="LevantACARS.Views.DispatchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="900"
             Background="#0a0a0c">
    
    <UserControl.Resources>
        <!-- Styles -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="#141418"/>
            <Setter Property="BorderBrush" Value="#fbbf2480"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20"/>
        </Style>

        <Style x:Key="HeaderTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#9ca3af"/>
        </Style>

        <Style x:Key="ValueTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style x:Key="TabButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#9ca3af"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#d1d5db"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ActiveTabButtonStyle" TargetType="Button" BasedOn="{StaticResource TabButtonStyle}">
            <Setter Property="BorderBrush" Value="#06b6d4"/>
            <Setter Property="Foreground" Value="#06b6d4"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#06b6d4" Offset="0"/>
                        <GradientStop Color="#2563eb" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="24,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid MaxWidth="900" Margin="40">
                <!-- Main Card -->
                <Border Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <Grid Grid.Row="0" Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Orientation="Horizontal">
                                <Border Width="40" Height="40" CornerRadius="4" Margin="0,0,12,0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#06b6d4" Offset="0"/>
                                            <GradientStop Color="#2563eb" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <TextBlock Text="✈" FontSize="20" Foreground="White" 
                                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel>
                                    <TextBlock Text="Import from SimBrief" FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                                    <TextBlock Text="Fetch your latest flight plan from SimBrief" FontSize="11" Foreground="#9ca3af"/>
                                </StackPanel>
                            </StackPanel>

                            <Button Grid.Column="1" Content="🔄 Refresh" 
                                    Command="{Binding RefreshFlightPlanCommand}"
                                    Background="#1f2937" Foreground="#d1d5db" 
                                    BorderBrush="#374151" BorderThickness="1"
                                    Padding="12,6" FontSize="12" Cursor="Hand"/>
                        </Grid>

                        <!-- Origin/Destination -->
                        <Grid Grid.Row="1" Margin="0,0,0,20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Origin -->
                            <StackPanel Grid.Row="0" Grid.Column="0">
                                <TextBlock Text="{Binding OriginIcao}" FontSize="28" FontWeight="Bold" Foreground="White"/>
                                <TextBlock Text="{Binding OriginName}" FontSize="10" Foreground="#9ca3af" Margin="0,2,0,8"/>
                                <TextBlock FontSize="12" Foreground="#6b7280">
                                    <Run Text="📍"/>
                                    <Run Text="{Binding OriginRunway}"/>
                                </TextBlock>
                            </StackPanel>

                            <!-- Flight Number -->
                            <StackPanel Grid.Row="0" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20,0">
                                <TextBlock Text="{Binding FlightNumber}" FontSize="12" Foreground="#06b6d4" HorizontalAlignment="Center"/>
                                <TextBlock Text="✈" FontSize="20" Foreground="#4b5563" HorizontalAlignment="Center" Margin="0,4"/>
                            </StackPanel>

                            <!-- Destination -->
                            <StackPanel Grid.Row="0" Grid.Column="2">
                                <TextBlock Text="{Binding DestinationIcao}" FontSize="28" FontWeight="Bold" Foreground="White"/>
                                <TextBlock Text="{Binding DestinationName}" FontSize="10" Foreground="#9ca3af" Margin="0,2,0,8"/>
                                <TextBlock FontSize="12" Foreground="#6b7280">
                                    <Run Text="📍"/>
                                    <Run Text="{Binding DestinationRunway}"/>
                                </TextBlock>
                            </StackPanel>

                            <!-- Flight Stats -->
                            <Grid Grid.Row="1" Grid.ColumnSpan="3" Margin="0,20,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Background="#1a1a20" CornerRadius="6" Padding="12" BorderBrush="#374151" BorderThickness="1" Margin="0,0,4,0">
                                    <StackPanel>
                                        <TextBlock Text="⏱ ETE" FontSize="10" Foreground="#9ca3af" Margin="0,0,0,4"/>
                                        <TextBlock Text="{Binding Ete}" FontSize="14" FontWeight="SemiBold" Foreground="White"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1" Background="#1a1a20" CornerRadius="6" Padding="12" BorderBrush="#374151" BorderThickness="1" Margin="4,0">
                                    <StackPanel>
                                        <TextBlock Text="📊 CRUISE" FontSize="10" Foreground="#9ca3af" Margin="0,0,0,4"/>
                                        <TextBlock Text="{Binding CruiseAltitude}" FontSize="14" FontWeight="SemiBold" Foreground="White"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2" Background="#1a1a20" CornerRadius="6" Padding="12" BorderBrush="#374151" BorderThickness="1" Margin="4,0">
                                    <StackPanel>
                                        <TextBlock Text="💨 AVG WIND" FontSize="10" Foreground="#9ca3af" Margin="0,0,0,4"/>
                                        <TextBlock Text="{Binding AvgWind}" FontSize="13" FontWeight="SemiBold" Foreground="White"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="3" Background="#1a1a20" CornerRadius="6" Padding="12" BorderBrush="#374151" BorderThickness="1" Margin="4,0,0,0">
                                    <StackPanel>
                                        <TextBlock Text="📈 CI" FontSize="10" Foreground="#9ca3af" Margin="0,0,0,4"/>
                                        <TextBlock Text="{Binding CostIndex}" FontSize="14" FontWeight="SemiBold" Foreground="White"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>

                        <!-- Tabs -->
                        <Border Grid.Row="2" BorderBrush="#374151" BorderThickness="0,0,0,1" Margin="0,0,0,20">
                            <StackPanel Orientation="Horizontal">
                                <Button Content="📋 Overview" 
                                        Style="{StaticResource ActiveTabButtonStyle}"
                                        Command="{Binding SetActiveTabCommand}"
                                        CommandParameter="overview"/>
                                <Button Content="⛽ Fuel" 
                                        Style="{StaticResource TabButtonStyle}"
                                        Command="{Binding SetActiveTabCommand}"
                                        CommandParameter="fuel"/>
                                <Button Content="⚖ Weights" 
                                        Style="{StaticResource TabButtonStyle}"
                                        Command="{Binding SetActiveTabCommand}"
                                        CommandParameter="weights"/>
                                <Button Content="🌤 Weather" 
                                        Style="{StaticResource TabButtonStyle}"
                                        Command="{Binding SetActiveTabCommand}"
                                        CommandParameter="weather"/>
                            </StackPanel>
                        </Border>

                        <!-- Content Area -->
                        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <!-- Route -->
                                <StackPanel Margin="0,0,0,20">
                                    <Grid Margin="0,0,0,8">
                                        <TextBlock Text="ROUTE" Style="{StaticResource HeaderTextStyle}"/>
                                        <Button Content="Copy" HorizontalAlignment="Right" FontSize="11" Foreground="#06b6d4" 
                                                Background="Transparent" BorderThickness="0" Cursor="Hand"/>
                                    </Grid>
                                    <Border Background="#0a0a0c" BorderBrush="#374151" BorderThickness="1" CornerRadius="4" Padding="12" MaxHeight="100">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <TextBlock Text="{Binding Route}" FontFamily="Consolas" FontSize="11" 
                                                     Foreground="#d1d5db" TextWrapping="Wrap" LineHeight="18"/>
                                        </ScrollViewer>
                                    </Border>
                                </StackPanel>

                                <!-- Fuel & Weights Grid -->
                                <Grid Margin="0,0,0,20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Fuel Summary -->
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="⛽ FUEL SUMMARY" Style="{StaticResource HeaderTextStyle}" Margin="0,0,0,12"/>
                                        <StackPanel>
                                            <Grid Margin="0,0,0,8">
                                                <TextBlock Text="Block Fuel" FontSize="13" Foreground="#9ca3af"/>
                                                <TextBlock Text="{Binding BlockFuel}" Style="{StaticResource ValueTextStyle}" HorizontalAlignment="Right"/>
                                            </Grid>
                                            <Border Height="1" Background="#374151" Margin="0,0,0,8"/>
                                            <Grid Margin="0,0,0,8">
                                                <TextBlock Text="Trip Fuel" FontSize="13" Foreground="#9ca3af"/>
                                                <TextBlock Text="{Binding TripFuel}" Style="{StaticResource ValueTextStyle}" HorizontalAlignment="Right"/>
                                            </Grid>
                                            <Border Height="1" Background="#374151" Margin="0,0,0,8"/>
                                            <Grid>
                                                <TextBlock Text="Landing Fuel" FontSize="13" Foreground="#9ca3af"/>
                                                <TextBlock Text="{Binding LandingFuel}" Style="{StaticResource ValueTextStyle}" HorizontalAlignment="Right"/>
                                            </Grid>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Weights Summary -->
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="⚖ WEIGHTS SUMMARY" Style="{StaticResource HeaderTextStyle}" Margin="0,0,0,12"/>
                                        <StackPanel>
                                            <Grid Margin="0,0,0,8">
                                                <TextBlock Text="ZFW" FontSize="13" Foreground="#9ca3af"/>
                                                <TextBlock Text="{Binding Zfw}" Style="{StaticResource ValueTextStyle}" HorizontalAlignment="Right"/>
                                            </Grid>
                                            <Border Height="1" Background="#374151" Margin="0,0,0,8"/>
                                            <Grid Margin="0,0,0,8">
                                                <TextBlock Text="TOW" FontSize="13" Foreground="#9ca3af"/>
                                                <TextBlock Text="{Binding Tow}" Style="{StaticResource ValueTextStyle}" HorizontalAlignment="Right"/>
                                            </Grid>
                                            <Border Height="1" Background="#374151" Margin="0,0,0,8"/>
                                            <Grid>
                                                <TextBlock Text="LDW" FontSize="13" Foreground="#9ca3af"/>
                                                <TextBlock Text="{Binding Ldw}" Style="{StaticResource ValueTextStyle}" HorizontalAlignment="Right"/>
                                            </Grid>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>

                                <!-- Payload & Alternate -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Payload -->
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="👥 PAYLOAD" Style="{StaticResource HeaderTextStyle}" Margin="0,0,0,12"/>
                                        <StackPanel>
                                            <Grid Margin="0,0,0,8">
                                                <TextBlock Text="Passengers" FontSize="13" Foreground="#9ca3af"/>
                                                <TextBlock Text="{Binding Passengers}" Style="{StaticResource ValueTextStyle}" HorizontalAlignment="Right"/>
                                            </Grid>
                                            <Border Height="1" Background="#374151" Margin="0,0,0,8"/>
                                            <Grid>
                                                <TextBlock Text="Cargo" FontSize="13" Foreground="#9ca3af"/>
                                                <TextBlock Text="{Binding Cargo}" Style="{StaticResource ValueTextStyle}" HorizontalAlignment="Right"/>
                                            </Grid>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Alternate -->
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="📍 ALTERNATE" Style="{StaticResource HeaderTextStyle}" Margin="0,0,0,12"/>
                                        <Border Background="#1a1a20" BorderBrush="#374151" BorderThickness="1" CornerRadius="6" Padding="12">
                                            <StackPanel>
                                                <TextBlock Text="{Binding AlternateIcao}" FontSize="16" FontWeight="Bold" Foreground="White"/>
                                                <TextBlock Text="{Binding AlternateName}" FontSize="10" Foreground="#9ca3af" Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- Footer -->
                        <Border Grid.Row="4" Background="#0f0f12" Margin="-20,-20,-20,-20" Padding="20" BorderBrush="#374151" BorderThickness="0,1,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0" Content="Cancel" Background="Transparent" Foreground="#9ca3af" 
                                    BorderThickness="0" FontSize="13" Padding="16,8" Cursor="Hand" HorizontalAlignment="Left"/>

                            <Button Grid.Column="1" Content="✈ Import Flight Plan" 
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Command="{Binding ImportFlightPlanCommand}"/>
                        </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>

        <!-- Loading Overlay -->
        <Border Background="#80000000" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="⏳" FontSize="48" HorizontalAlignment="Center"/>
                <TextBlock Text="Loading flight plan..." FontSize="14" Foreground="White" Margin="0,12,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
