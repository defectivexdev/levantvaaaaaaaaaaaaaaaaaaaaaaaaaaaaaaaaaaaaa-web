<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi"
     xmlns:util="http://schemas.microsoft.com/wix/UtilExtension">
  
  <!-- Product Definition -->
  <Product Id="*" 
           Name="Levant ACARS" 
           Language="1033" 
           Version="3.0.0.0" 
           Manufacturer="Levant Virtual Airlines" 
           UpgradeCode="12345678-1234-1234-1234-123456789012">
    
    <Package InstallerVersion="500" 
             Compressed="yes" 
             InstallScope="perMachine"
             Description="Levant ACARS - Professional Flight Management System"
             Comments="Advanced ACARS system for virtual airline operations"
             Manufacturer="Levant Virtual Airlines" />

    <!-- Upgrade Configuration -->
    <MajorUpgrade DowngradeErrorMessage="A newer version of Levant ACARS is already installed." 
                  AllowSameVersionUpgrades="yes" />
    
    <!-- Media Configuration -->
    <MediaTemplate EmbedCab="yes" CompressionLevel="high" />

    <!-- Custom Icons -->
    <Icon Id="AppIcon.ico" SourceFile="Assets\icon.ico" />
    <Property Id="ARPPRODUCTICON" Value="AppIcon.ico" />
    
    <!-- Add/Remove Programs Configuration -->
    <Property Id="ARPHELPLINK" Value="https://levant-va.com/support" />
    <Property Id="ARPURLINFOABOUT" Value="https://levant-va.com" />
    
    <!-- Custom UI -->
    <WixVariable Id="WixUILicenseRtf" Value="Assets\License.rtf" />
    <WixVariable Id="WixUIBannerBmp" Value="Assets\Banner.bmp" />
    <WixVariable Id="WixUIDialogBmp" Value="Assets\Dialog.bmp" />
    
    <!-- Beautiful Custom UI Sequence -->
    <UI Id="CustomUI">
      <UIRef Id="WixUI_Minimal" />
      <UIRef Id="WixUI_ErrorProgressText" />
      
      <!-- Custom Welcome Dialog -->
      <Publish Dialog="WelcomeDlg" Control="Next" Event="NewDialog" Value="InstallDirDlg">1</Publish>
      
      <!-- Branding -->
      <ProgressText Action="InstallFiles">Installing Levant ACARS...</ProgressText>
      <ProgressText Action="RemoveFiles">Removing previous version...</ProgressText>
    </UI>

    <!-- Feature Configuration -->
    <Feature Id="ProductFeature" 
             Title="Levant ACARS" 
             Description="Complete ACARS installation with all features"
             Level="1"
             ConfigurableDirectory="INSTALLFOLDER"
             AllowAdvertise="no"
             Display="expand">
      
      <!-- Core Application -->
      <Feature Id="CoreApp" 
               Title="Core Application" 
               Description="Main ACARS application (Required)"
               Level="1"
               Absent="disallow">
        <ComponentGroupRef Id="ProductComponents" />
        <ComponentRef Id="ApplicationShortcut" />
        <ComponentRef Id="DesktopShortcut" />
      </Feature>
      
      <!-- Documentation -->
      <Feature Id="Documentation" 
               Title="Documentation" 
               Description="User guides and documentation"
               Level="1">
        <ComponentGroupRef Id="DocumentationComponents" />
      </Feature>
    </Feature>

    <!-- Installation Directory -->
    <Directory Id="TARGETDIR" Name="SourceDir">
      <!-- Program Files -->
      <Directory Id="ProgramFilesFolder">
        <Directory Id="CompanyFolder" Name="Levant Virtual Airlines">
          <Directory Id="INSTALLFOLDER" Name="Levant ACARS">
            
            <!-- Main Application Files -->
            <Component Id="MainExecutable" Guid="*">
              <File Id="LevantACARSExe" 
                    Source="$(var.BuildPath)\LevantACARS.exe" 
                    KeyPath="yes">
                <Shortcut Id="StartMenuShortcut"
                          Directory="ProgramMenuFolder"
                          Name="Levant ACARS"
                          Description="Professional Flight Management System"
                          Icon="AppIcon.ico"
                          WorkingDirectory="INSTALLFOLDER"
                          Advertise="no" />
              </File>
            </Component>

            <!-- Configuration Files -->
            <Component Id="ConfigFiles" Guid="*">
              <File Id="ConfigIni" Source="$(var.BuildPath)\config.ini" KeyPath="yes" />
            </Component>

            <!-- Web UI Files -->
            <Directory Id="WebUIFolder" Name="wwwroot">
              <Component Id="WebUIFiles" Guid="*">
                <File Id="IndexHtml" Source="$(var.WebUIPath)\index.html" KeyPath="yes" />
                <!-- Add more web files via heat.exe -->
              </Component>
            </Directory>

          </Directory>
        </Directory>
      </Directory>

      <!-- Start Menu -->
      <Directory Id="ProgramMenuFolder">
        <Component Id="ApplicationShortcut" Guid="*">
          <RegistryValue Root="HKCU" 
                        Key="Software\LevantVA\LevantACARS" 
                        Name="installed" 
                        Type="integer" 
                        Value="1" 
                        KeyPath="yes" />
          <RemoveFolder Id="RemoveProgramMenuFolder" On="uninstall" />
        </Component>
      </Directory>

      <!-- Desktop -->
      <Directory Id="DesktopFolder">
        <Component Id="DesktopShortcut" Guid="*">
          <Shortcut Id="DesktopShortcutId"
                    Name="Levant ACARS"
                    Description="Professional Flight Management System"
                    Target="[INSTALLFOLDER]LevantACARS.exe"
                    Icon="AppIcon.ico"
                    WorkingDirectory="INSTALLFOLDER" />
          <RegistryValue Root="HKCU" 
                        Key="Software\LevantVA\LevantACARS" 
                        Name="desktopShortcut" 
                        Type="integer" 
                        Value="1" 
                        KeyPath="yes" />
        </Component>
      </Directory>
    </Directory>

    <!-- Custom Actions -->
    <CustomAction Id="LaunchApplication"
                  FileKey="LevantACARSExe"
                  ExeCommand=""
                  Execute="immediate"
                  Impersonate="yes"
                  Return="asyncNoWait" />

    <!-- Install Sequences -->
    <InstallExecuteSequence>
      <Custom Action="LaunchApplication" After="InstallFinalize">
        NOT Installed AND NOT REMOVE
      </Custom>
    </InstallExecuteSequence>

  </Product>

  <!-- Component Groups -->
  <Fragment>
    <ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">
      <ComponentRef Id="MainExecutable" />
      <ComponentRef Id="ConfigFiles" />
      <ComponentRef Id="WebUIFiles" />
    </ComponentGroup>

    <ComponentGroup Id="DocumentationComponents" Directory="INSTALLFOLDER">
      <Component Id="ReadmeFile" Guid="*">
        <File Id="ReadmeMd" Source="README.md" KeyPath="yes" />
      </Component>
      <Component Id="ConfigGuide" Guid="*">
        <File Id="ConfigGuideMd" Source="CONFIG_INI_GUIDE.md" KeyPath="yes" />
      </Component>
    </ComponentGroup>
  </Fragment>

</Wix>
